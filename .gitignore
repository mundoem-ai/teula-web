# ============================================================
#  .gitignore — Web Teula Sistemas (sitio estático)
# ============================================================

# --- Secretos y variables de entorno (NUNCA subir) ---
.env
.env.*
*.local
secrets.json
secrets.*
credentials*.json
*.pem
*.key
*.pfx
*.p12
*.crt
id_rsa*
*.token

# --- Sistema operativo ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# --- Editores / IDE ---
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# --- Dependencias y herramientas (por si se usan) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.cache/

# --- Utilidades de desarrollo / servidores locales ---
server.cjs
serve.cjs
*.log

# --- Temporales / build ---
tmp/
temp/
.tmp/
dist/
build/
